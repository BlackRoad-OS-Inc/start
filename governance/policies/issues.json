{
  "policy": "issues",
  "version": "1.0.0",
  "rules": [
    {
      "id": "IS-001",
      "rule": "Use issue templates",
      "severity": "high"
    },
    {
      "id": "IS-002",
      "rule": "Label appropriately",
      "severity": "high"
    },
    {
      "id": "IS-003",
      "rule": "Link to milestones",
      "severity": "high"
    },
    {
      "id": "IS-004",
      "rule": "Assign when working",
      "severity": "high"
    },
    {
      "id": "IS-005",
      "rule": "Close with commit ref",
      "severity": "high"
    }
  ]
}