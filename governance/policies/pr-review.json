{
  "policy": "pr-review",
  "version": "1.0.0",
  "rules": [
    {
      "id": "PR-001",
      "rule": "Title under 70 chars",
      "severity": "high"
    },
    {
      "id": "PR-002",
      "rule": "Body has Summary+Test Plan",
      "severity": "high"
    },
    {
      "id": "PR-003",
      "rule": "Requires @blackboxprogramming",
      "severity": "high"
    },
    {
      "id": "PR-004",
      "rule": "No self-merge",
      "severity": "high"
    },
    {
      "id": "PR-005",
      "rule": "Squash merge preferred",
      "severity": "high"
    },
    {
      "id": "PR-006",
      "rule": "Delete branch after merge",
      "severity": "high"
    }
  ]
}