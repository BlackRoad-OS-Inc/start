{
  "policy": "coding",
  "version": "1.0.0",
  "rules": [
    {
      "id": "CS-001",
      "rule": "All code proprietary",
      "severity": "high"
    },
    {
      "id": "CS-002",
      "rule": "brand.blackroad.io canonical",
      "severity": "high"
    },
    {
      "id": "CS-003",
      "rule": "No hardcoded secrets",
      "severity": "high"
    },
    {
      "id": "CS-004",
      "rule": "Rate limiting on endpoints",
      "severity": "high"
    },
    {
      "id": "CS-005",
      "rule": "Input validation on APIs",
      "severity": "high"
    },
    {
      "id": "CS-006",
      "rule": "/api/health on every Worker",
      "severity": "high"
    },
    {
      "id": "CS-007",
      "rule": "OpenAPI spec for APIs",
      "severity": "high"
    },
    {
      "id": "CS-008",
      "rule": "PBKDF2 310K iterations",
      "severity": "high"
    },
    {
      "id": "CS-009",
      "rule": "Auth via header only",
      "severity": "high"
    },
    {
      "id": "CS-010",
      "rule": "Max-width 1100px",
      "severity": "high"
    }
  ]
}