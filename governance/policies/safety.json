{
  "policy": "safety",
  "version": "1.0.0",
  "rules": [
    {
      "id": "SA-001",
      "rule": "Stop when uncertain",
      "severity": "high"
    },
    {
      "id": "SA-002",
      "rule": "Never force-push main",
      "severity": "high"
    },
    {
      "id": "SA-003",
      "rule": "Never delete without confirm",
      "severity": "high"
    },
    {
      "id": "SA-004",
      "rule": "Never commit .env/creds",
      "severity": "high"
    },
    {
      "id": "SA-005",
      "rule": "Never bypass hooks",
      "severity": "high"
    },
    {
      "id": "SA-006",
      "rule": "Never amend published commits",
      "severity": "high"
    },
    {
      "id": "SA-007",
      "rule": "Never rm -rf without confirm",
      "severity": "high"
    },
    {
      "id": "SA-008",
      "rule": "Never push without request",
      "severity": "high"
    },
    {
      "id": "SA-009",
      "rule": "Verify SSH targets",
      "severity": "high"
    },
    {
      "id": "SA-010",
      "rule": "Test before deploy",
      "severity": "high"
    }
  ]
}